---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { categoryLabel, categoryEmoji } from '../../data/categories';
import { issueUrl, link, asset } from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const d = project.data;

// 同作者的其它项目
const all = await getCollection('projects');
const moreByAuthor = all
  .filter((p) => p.id !== project.id && p.data.author === d.author)
  .slice(0, 4);

const dateStr = d.date.toLocaleDateString('zh-CN');

// 封面 + 附加截图，组成 App Store 风格画廊（封面永远是第一张）
const gallery = [d.cover, ...(d.screenshots ?? [])];
---

<Base title={d.title} description={d.summary}>
  <div class="container detail">
    <a class="back" href={link('/')}>← 返回发现</a>

    <div class="detail-grid">
      <div>
        <div class="gallery" data-gallery data-count={gallery.length}>
          {
            gallery.map((src, i) => (
              <button class="shot" type="button" data-idx={i} aria-label={`查看截图 ${i + 1}`}>
                <img
                  src={asset(src)}
                  alt={`${d.title} 截图 ${i + 1}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </button>
            ))
          }
        </div>
      </div>

      <div>
        <span class="card cat" style="background:transparent;border:none;padding:0">
          {categoryEmoji(d.category)} {categoryLabel(d.category)}
        </span>
        <h1>{d.title}</h1>
        <p class="lead">{d.summary}</p>

        {
          d.tags.length > 0 && (
            <div class="kvs">
              {d.tags.map((t) => <span class="tag">#{t}</span>)}
            </div>
          )
        }

        {
          d.madeWith.length > 0 && (
            <div class="madewith">
              <span class="madewith-label">⚡ 用什么做的</span>
              <div class="kvs">
                {d.madeWith.map((t) => <span class="tag tool">{t}</span>)}
              </div>
            </div>
          )
        }

        <div class="actions-row">
          {
            d.liveUrl && (
              <a class="btn primary" href={d.liveUrl} target="_blank" rel="noopener">
                🌐 在线体验
              </a>
            )
          }
          {
            d.repoUrl && (
              <a class="btn" href={d.repoUrl} target="_blank" rel="noopener">
                💻 查看源码
              </a>
            )
          }
          {
            d.downloadUrl && (
              <a class="btn" href={d.downloadUrl} target="_blank" rel="noopener">
                ⬇️ 下载
              </a>
            )
          }
          <a class="btn accent" href={issueUrl(d.issueNumber)} target="_blank" rel="noopener">
            🔥 点赞投票 {d.votes}
          </a>
        </div>

        {
          d.qrcode && (
            <div class="qrcard">
              <img src={asset(d.qrcode)} alt={`${d.title} 二维码`} />
              <div class="hint">扫码体验（小程序 / 小游戏）</div>
            </div>
          )
        }

        <div class="author-card">
          <div class="name">👤 {d.author} <span class="role">造物家</span></div>
          <div class="hint" style="color:var(--text-dim);font-size:13px">
            发布于 {dateStr}
            {
              d.authorUrl && (
                <>
                  ·{' '}
                  <a href={d.authorUrl} target="_blank" rel="noopener" style="color:var(--brand-2)">
                    作者主页
                  </a>
                </>
              )
            }
          </div>
        </div>
      </div>
    </div>

    {
      d.story && (
        <section class="story">
          <div class="section-title">
            <h2>项目故事</h2>
          </div>
          <div class="story-body">{d.story}</div>
        </section>
      )
    }

    {
      moreByAuthor.length > 0 && (
        <>
          <div class="section-title">
            <h2>{d.author} 的其它项目</h2>
          </div>
          <div class="grid">
            {moreByAuthor.map((p) => (
              <a class="card" href={link(`/projects/${p.id}`)}>
                <img class="cover" src={asset(p.data.cover)} alt={p.data.title} loading="lazy" />
                <div class="body">
                  <h3>{p.data.title}</h3>
                  <p class="summary">{p.data.summary}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )
    }
  </div>

  <div class="lightbox" data-lightbox hidden aria-hidden="true">
    <button class="lb-btn lb-close" type="button" aria-label="关闭">✕</button>
    <button class="lb-btn lb-prev" type="button" aria-label="上一张">‹</button>
    <img class="lb-img" src="" alt="" />
    <button class="lb-btn lb-next" type="button" aria-label="下一张">›</button>
    <div class="lb-count"></div>
  </div>
</Base>

<script>
  const gallery = document.querySelector<HTMLElement>('[data-gallery]');
  const lb = document.querySelector<HTMLElement>('[data-lightbox]');
  if (gallery && lb) {
    const shots = Array.from(gallery.querySelectorAll<HTMLButtonElement>('.shot'));
    const srcs = shots.map((s) => s.querySelector('img')?.src ?? '');
    const lbImg = lb.querySelector<HTMLImageElement>('.lb-img')!;
    const lbCount = lb.querySelector<HTMLElement>('.lb-count')!;
    const btnPrev = lb.querySelector<HTMLButtonElement>('.lb-prev')!;
    const btnNext = lb.querySelector<HTMLButtonElement>('.lb-next')!;
    const btnClose = lb.querySelector<HTMLButtonElement>('.lb-close')!;
    const single = srcs.length <= 1;
    let idx = 0;

    function show(i: number) {
      idx = (i + srcs.length) % srcs.length;
      lbImg.src = srcs[idx];
      lbCount.textContent = `${idx + 1} / ${srcs.length}`;
    }
    function open(i: number) {
      show(i);
      lb!.hidden = false;
      lb!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb!.hidden = true;
      lb!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    btnPrev.hidden = single;
    btnNext.hidden = single;
    lbCount.hidden = single;

    shots.forEach((s, i) => s.addEventListener('click', () => open(i)));
    btnPrev.addEventListener('click', (e) => {
      e.stopPropagation();
      show(idx - 1);
    });
    btnNext.addEventListener('click', (e) => {
      e.stopPropagation();
      show(idx + 1);
    });
    btnClose.addEventListener('click', close);
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lb!.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft' && !single) show(idx - 1);
      else if (e.key === 'ArrowRight' && !single) show(idx + 1);
    });
  }
</script>
