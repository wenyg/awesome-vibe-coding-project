---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { categoryLabel, categoryEmoji } from '../../data/categories';
import { issueUrl } from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const d = project.data;

// 同作者的其它项目
const all = await getCollection('projects');
const moreByAuthor = all
  .filter((p) => p.id !== project.id && p.data.author === d.author)
  .slice(0, 4);

const dateStr = d.date.toLocaleDateString('zh-CN');
---

<Base title={d.title} description={d.summary}>
  <div class="container detail">
    <a class="back" href="/">← 返回发现</a>

    <div class="detail-grid">
      <div>
        <img class="detail-cover" src={d.cover} alt={d.title} transition:name={`cover-${project.id}`} />
      </div>

      <div>
        <span class="card cat" style="background:transparent;border:none;padding:0">
          {categoryEmoji(d.category)} {categoryLabel(d.category)}
        </span>
        <h1 transition:name={`title-${project.id}`}>{d.title}</h1>
        <p class="lead">{d.summary}</p>

        {
          d.tags.length > 0 && (
            <div class="kvs">
              {d.tags.map((t) => <span class="tag">#{t}</span>)}
            </div>
          )
        }

        <div class="actions-row">
          {
            d.liveUrl && (
              <a class="btn primary" href={d.liveUrl} target="_blank" rel="noopener">
                🌐 在线体验
              </a>
            )
          }
          {
            d.repoUrl && (
              <a class="btn" href={d.repoUrl} target="_blank" rel="noopener">
                💻 查看源码
              </a>
            )
          }
          {
            d.downloadUrl && (
              <a class="btn" href={d.downloadUrl} target="_blank" rel="noopener">
                ⬇️ 下载
              </a>
            )
          }
          <a class="btn accent" href={issueUrl(d.issueNumber)} target="_blank" rel="noopener">
            🔥 点赞投票 {d.votes}
          </a>
        </div>

        {
          d.qrcode && (
            <div class="qrcard">
              <img src={d.qrcode} alt={`${d.title} 二维码`} />
              <div class="hint">扫码体验（小程序 / 小游戏）</div>
            </div>
          )
        }

        <div class="author-card">
          <div class="name">👤 {d.author}</div>
          <div class="hint" style="color:var(--text-dim);font-size:13px">
            发布于 {dateStr}
            {
              d.authorUrl && (
                <>
                  ·{' '}
                  <a href={d.authorUrl} target="_blank" rel="noopener" style="color:var(--brand-2)">
                    作者主页
                  </a>
                </>
              )
            }
          </div>
        </div>
      </div>
    </div>

    {
      moreByAuthor.length > 0 && (
        <>
          <div class="section-title">
            <h2>{d.author} 的其它项目</h2>
          </div>
          <div class="grid">
            {moreByAuthor.map((p) => (
              <a class="card" href={`/projects/${p.id}`}>
                <img class="cover" src={p.data.cover} alt={p.data.title} loading="lazy" />
                <div class="body">
                  <h3>{p.data.title}</h3>
                  <p class="summary">{p.data.summary}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )
    }
  </div>
</Base>
