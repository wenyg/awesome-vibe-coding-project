---
import { categoryLabel, categoryEmoji } from '../data/categories';
import { link, asset } from '../data/site';

interface Props {
  id: string;
  title: string;
  summary: string;
  cover: string;
  category: string;
  author: string;
  votes: number;
  featured?: boolean;
  date: Date;
  liveUrl?: string;
  repoUrl?: string;
  downloadUrl?: string;
  qrcode?: string;
}

const { id, title, summary, cover, category, author, votes, featured, date, liveUrl, repoUrl, downloadUrl, qrcode } =
  Astro.props;
const ts = date instanceof Date ? date.getTime() : new Date(date).getTime();
const signals = [
  liveUrl ? '可体验' : '',
  qrcode ? '可扫码' : '',
  repoUrl ? '有源码' : '',
  downloadUrl ? '可下载' : '',
].filter(Boolean);
const voteLabel = votes > 0 ? `🔥 ${votes}` : '新上架';
---

<a
  class="card"
  href={link(`/projects/${id}`)}
  data-category={category}
  data-votes={votes}
  data-date={ts}
  data-search={`${title} ${summary} ${author} ${categoryLabel(category)}`.toLowerCase()}
>
  <div class="cover-wrap">
    {featured && <span class="badge-featured">精选</span>}
    <img class="cover" src={asset(cover)} alt={title} loading="lazy" />
  </div>
  <div class="body">
    <span class="cat">{categoryEmoji(category)} {categoryLabel(category)}</span>
    <h3>{title}</h3>
    <p class="summary">{summary}</p>
    {
      signals.length > 0 && (
        <div class="signals" aria-label="项目可用性">
          {signals.map((signal) => <span>{signal}</span>)}
        </div>
      )
    }
    <div class="meta">
      <span class="author">👤 {author}</span>
      <span class={`votes ${votes === 0 ? 'is-new' : ''}`}>{voteLabel}</span>
    </div>
  </div>
</a>
