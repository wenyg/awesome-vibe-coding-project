{
  // Cloudflare Workers 静态资源部署（assets-only，无需 Worker 脚本）
  // 把 Astro 构建产物 dist/ 作为静态站点直接托管。
  "name": "awesome-vibe-coding-project",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./dist",
    // 多页静态站：自动处理目录到 index.html 的映射
    "html_handling": "auto-trailing-slash"
  }
}
